{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://artemis.local/schemas/artemis-event-log.schema.json",
  "title": "ARTEMIS Event Log",
  "description": "Canonical append-only event log envelope for ARTEMIS adapters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "events"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "./artemis-event.schema.json"
      }
    }
  }
}
